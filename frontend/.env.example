# Copy to .env.local for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables.

# Public Firebase client config (from Firebase Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: FastAPI on Railway / Render — no trailing slash
# Example: https://your-service.up.railway.app
VITE_BACKEND_URL=

# Optional: Firebase callable HTTP functions base URL
# VITE_FIREBASE_FUNCTIONS_URL=
