# Railway / Render / local uvicorn — copy to .env if your runner loads dotenv (optional).

# Comma-separated browser origins allowed to call this API (Vercel URL + local dev).
# If unset, CORS allows * with credentials disabled (fine for simple JSON fetch).
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Host port (Railway and Render inject PORT automatically)
PORT=8000
